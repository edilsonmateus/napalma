generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  roda_samba
  pagode
  gafieira
  samba_rock
  feijoada_sambista
}

enum UserRole {
  admin
  producer
  venue_manager
  attendee
}

// Internal operational permissions are deliberately separate from the public
// account role. A person can assist a specific queue without becoming a global
// application administrator.
enum OperationScope {
  privacy
  claims
  catalog
  notifications
  audit
  settings
}

enum AdCampaignStatus {
  draft
  active
  paused
  ended
}

enum AdSlot {
  explore_feed_large
  venue_detail_inline
  radar_header
  venue_menu_sponsor
}

enum VenueMenuStatus {
  draft
  published
  archived
}

enum VenueMenuItemStatus {
  draft
  published
  unavailable
  archived
}

enum VenueMenuPriceMode {
  exact
  from
  hidden
  consultation
}

enum VenueMenuInteractionType {
  want_to_try
  recommend
  save
}

enum AdEventType {
  impression
  click
}

enum AdReviewStatus {
  draft
  pending_review
  approved
  rejected
  changes_requested
}

enum AdReviewEntityType {
  campaign
  creative
}

enum AdReviewAction {
  submit
  approve
  reject
  request_changes
  reopen_after_edit
}

enum AdvertiserAccountType {
  unclassified
  venue
  producer
  artist
  brand
  agency
  group
  internal
}

enum AdvertiserAccountStatus {
  draft
  pending_review
  active
  suspended
  rejected
  archived
}

enum AdvertiserMembershipRole {
  owner
  admin
  campaign_manager
  analyst
  billing_manager
  viewer
}

enum AdvertiserMembershipStatus {
  invited
  active
  suspended
  revoked
}

enum AdPaymentProvider {
  mock
  mercado_pago
}

enum AdPaymentStatus {
  created
  pending
  approved
  rejected
  cancelled
  expired
  refunded
}

enum AdCreditLedgerType {
  purchase
  campaign_allocation
  delivery_charge
  campaign_refund
  payment_refund
  admin_adjustment
}

enum ClaimTargetType {
  venue
  artist
}

enum ClaimStatus {
  pending
  approved
  rejected
}

enum ArtistAccessRole {
  owner
  manager
  editor
  viewer
}

enum ArtistAccessStatus {
  invited
  active
  suspended
  revoked
}

enum ArtistBookingStatus {
  new
  in_conversation
  proposal_sent
  won
  lost
  archived
  spam
}

enum ArtistMediaType {
  photo
  video_external
}

enum PrivacyConsentPurpose {
  cultural_personalization
  ads_personalization
}

enum PrivacyRequestType {
  access
  data_export
  deletion
  anonymization
  correction
  opposition
}

enum PrivacyRequestStatus {
  received
  in_review
  completed
  rejected
  cancelled
}

model User {
  id                              String    @id @default(uuid())
  email                           String    @unique
  username                        String    @unique
  firstName                       String
  lastName                        String
  phone                           String?
  instagramHandle                 String?
  avatarUrl                       String?
  city                            String?
  neighborhood                    String?
  postalCode                      String?
  passwordHash                    String
  role                            UserRole  @default(attendee)
  canUseReservedBrandUsername     Boolean   @default(false)
  reservedUsernameGrantedByUserId String?
  reservedUsernameGrantedAt       DateTime?

  markedEvents                 MarkedEvent[]
  historyEntries               UserEventHistory[]
  achievements                 UserAchievement[]
  createdVenues                Venue[]                       @relation("VenueCreatedBy")
  managedVenues                Venue[]                       @relation("VenueManagedBy")
  venueAccesses                VenueManagerAccess[]
  createdArtists               Artist[]                      @relation("ArtistCreatedBy")
  createdEvents                Event[]                       @relation("EventCreatedBy")
  refreshTokens                RefreshToken[]
  passwordResetTokens          PasswordResetToken[]
  adCampaigns                  AdCampaign[]
  adEvents                     AdEventLog[]
  itineraries                  Itinerary[]
  audienceVisits               AudienceVisitor[]
  pushSubscriptions            PushSubscription[]
  toNaPistaSessions            ToNaPistaSession[]
  producerVenueAccesses        ProducerVenueAccess[]
  producerArtistAccesses       ProducerArtistAccess[]
  artistFollows                ArtistFollow[]
  claims                       ClaimRequest[]                @relation("ClaimRequestedBy")
  claimsReviewed               ClaimRequest[]                @relation("ClaimReviewedBy")
  createdRegions               Region[]                      @relation("RegionCreatedBy")
  acquisitionLeads             AcquisitionLead[]             @relation("AcquisitionLeadCreatedBy")
  acquisitionInteractions      AcquisitionInteraction[]      @relation("AcquisitionInteractionCreatedBy")
  acquisitionStatusChanges     AcquisitionStatusHistory[]    @relation("AcquisitionStatusChangedBy")
  advertiserAccountsCreated    AdvertiserAccount[]           @relation("AdvertiserAccountCreatedBy")
  advertiserAccountsApproved   AdvertiserAccount[]           @relation("AdvertiserAccountApprovedBy")
  advertiserMemberships        AdvertiserMembership[]        @relation("AdvertiserMembershipUser")
  advertiserMembershipInvites  AdvertiserMembership[]        @relation("AdvertiserMembershipInvitedBy")
  adCampaignReviews            AdCampaign[]                  @relation("AdCampaignReviewedBy")
  adCreativeReviews            AdCreative[]                  @relation("AdCreativeReviewedBy")
  adReviewActions              AdReviewLog[]                 @relation("AdReviewLogActor")
  adPaymentOrdersCreated       AdPaymentOrder[]              @relation("AdPaymentOrderCreatedBy")
  adCreditEntriesCreated       AdCreditLedgerEntry[]         @relation("AdCreditLedgerEntryCreatedBy")
  artistAccesses               ArtistAccess[]                @relation("ArtistAccessUser")
  artistAccessInvites          ArtistAccess[]                @relation("ArtistAccessInvitedBy")
  artistsVerified              Artist[]                      @relation("ArtistVerifiedBy")
  artistBookingRequests        ArtistBookingRequest[]        @relation("ArtistBookingRequester")
  privacyConsentRecords        PrivacyConsentRecord[]
  privacyRequests              PrivacyRequest[]              @relation("PrivacyRequestRequester")
  privacyRequestsHandled       PrivacyRequest[]              @relation("PrivacyRequestHandledBy")
  auditLogs                    AuditLog[]                    @relation("AuditLogActor")
  venueMenuInteractions        VenueMenuInteraction[]
  menuReviews                  VenueMenu[]                   @relation("VenueMenuReviewedBy")
  menuAdInventoryAcceptances   VenueMenu[]                   @relation("VenueMenuAdInventoryAcceptedBy")
  operationAccessGrants        OperationAccessGrant[]        @relation("OperationAccessGrantUser")
  operationAccessGrantsIssued  OperationAccessGrant[]        @relation("OperationAccessGrantIssuer")
  operationWebAuthnCredentials OperationWebAuthnCredential[]
  operationWebAuthnChallenges  OperationWebAuthnChallenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OperationAccessGrant {
  id              String         @id @default(uuid())
  userId          String
  scope           OperationScope
  grantedByUserId String
  createdAt       DateTime       @default(now())
  revokedAt       DateTime?

  user      User @relation("OperationAccessGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User @relation("OperationAccessGrantIssuer", fields: [grantedByUserId], references: [id], onDelete: Restrict)

  @@unique([userId, scope])
  @@index([userId, revokedAt])
  @@index([scope, revokedAt])
}

model OperationWebAuthnCredential {
  id           String    @id @default(uuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      Int       @default(0)
  transports   Json?
  deviceType   String?
  backedUp     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model OperationWebAuthnChallenge {
  id        String    @id @default(uuid())
  userId    String
  purpose   String
  challenge String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, purpose])
  @@index([expiresAt])
}

model PrivacyConsentRecord {
  id            String                @id @default(uuid())
  userId        String
  purpose       PrivacyConsentPurpose
  policyVersion String
  isGranted     Boolean
  source        String                @default("privacy_center")
  createdAt     DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
}

model PrivacyRequest {
  id              String               @id @default(uuid())
  userId          String
  type            PrivacyRequestType
  status          PrivacyRequestStatus @default(received)
  details         String?
  requestedAt     DateTime             @default(now())
  dueAt           DateTime?
  resolvedAt      DateTime?
  handledByUserId String?
  resolutionNote  String?

  user      User  @relation("PrivacyRequestRequester", fields: [userId], references: [id], onDelete: Cascade)
  handledBy User? @relation("PrivacyRequestHandledBy", fields: [handledByUserId], references: [id], onDelete: SetNull)

  @@index([userId, requestedAt])
  @@index([status, requestedAt])
  @@index([status, dueAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  subjectType String
  subjectId   String?
  metadata    Json?
  ipHash      String?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([subjectType, subjectId, createdAt])
  @@index([action, createdAt])
}

model Region {
  id                         String   @id @default(uuid())
  name                       String
  city                       String   @default("Sao Paulo")
  state                      String   @default("SP")
  grammarArticle             String?
  grammarPreposition         String?  @default("em")
  displayNameWithArticle     String?
  displayNameWithPreposition String?
  isActive                   Boolean  @default(true)
  sortOrder                  Int      @default(0)
  createdByUserId            String?
  createdBy                  User?    @relation("RegionCreatedBy", fields: [createdByUserId], references: [id])
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([name, city, state])
  @@index([isActive, sortOrder, name])
}

model AudienceVisitor {
  id          String    @id @default(uuid())
  visitorId   String    @unique
  userId      String?
  linkedAt    DateTime?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  hits        Int       @default(1)

  user User? @relation(fields: [userId], references: [id])

  @@index([lastSeenAt])
  @@index([userId])
  @@index([linkedAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  authKey   String
  userId    String?
  visitorId String?
  platform  String?
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([visitorId])
  @@index([isActive])
}

model ToNaPistaSession {
  id                String   @id @default(uuid())
  userId            String?
  visitorId         String?
  latitude          Float
  longitude         Float
  startsAt          DateTime @default(now())
  expiresAt         DateTime
  maxNotifications  Int      @default(2)
  notificationsSent Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  deliveries ToNaPistaDelivery[]

  @@index([userId, isActive, expiresAt])
  @@index([visitorId, isActive, expiresAt])
}

model ToNaPistaDelivery {
  id        String   @id @default(uuid())
  sessionId String
  eventId   String
  sentAt    DateTime @default(now())

  session ToNaPistaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  event   Event            @relation(fields: [eventId], references: [id])

  @@unique([sessionId, eventId])
  @@index([eventId, sentAt])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  type      String
  visitorId String?
  userId    String?
  venueId   String?
  eventId   String?
  artistId  String?
  region    String?
  city      String?
  state     String?
  source    String?
  metadata  Json?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([visitorId, createdAt])
  @@index([userId, createdAt])
  @@index([venueId, type, createdAt])
  @@index([eventId, type, createdAt])
  @@index([artistId, type, createdAt])
  @@index([region, createdAt])
  @@index([city, createdAt])
}

model Itinerary {
  id                  String   @id @default(uuid())
  userId              String
  title               String
  date                DateTime
  mode                String   @default("manual") // manual | automatic
  status              String   @default("draft") // draft | active | completed
  totalTransitMinutes Int      @default(0)
  riskScore           Int      @default(0)

  user  User            @relation(fields: [userId], references: [id])
  items ItineraryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

model ItineraryItem {
  id                     String @id @default(uuid())
  itineraryId            String
  eventId                String
  position               Int
  transitMinutesFromPrev Int    @default(0)
  riskLevel              String @default("ok") // ok | tight | risky

  itinerary Itinerary @relation(fields: [itineraryId], references: [id])
  event     Event     @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itineraryId, eventId])
  @@unique([itineraryId, position])
  @@index([eventId])
}

model AdCampaign {
  id                      String           @id @default(uuid())
  advertiser              String
  name                    String
  status                  AdCampaignStatus @default(draft)
  startsAt                DateTime?
  endsAt                  DateTime?
  priority                Int              @default(1)
  frequencyCapDaily       Int              @default(3)
  runInAllSlots           Boolean          @default(false)
  isEnabled               Boolean          @default(true)
  targeting               Json?
  createdByUserId         String?
  advertiserAccountId     String?
  reviewStatus            AdReviewStatus?
  submittedAt             DateTime?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  reviewedByUserId        String?
  reviewNotes             String?
  requiresReviewAfterEdit Boolean          @default(false)
  budgetCredits           Int              @default(0)
  spentCredits            Int              @default(0)

  createdBy         User?                 @relation(fields: [createdByUserId], references: [id])
  advertiserAccount AdvertiserAccount?    @relation(fields: [advertiserAccountId], references: [id], onDelete: SetNull)
  reviewedBy        User?                 @relation("AdCampaignReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  creatives         AdCreative[]
  events            AdEventLog[]
  deliveries        AdDelivery[]
  paymentOrders     AdPaymentOrder[]
  creditEntries     AdCreditLedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advertiserAccountId, status])
  @@index([reviewStatus, submittedAt])
}

model AdvertiserAccount {
  id                 String                  @id @default(uuid())
  name               String
  type               AdvertiserAccountType   @default(unclassified)
  status             AdvertiserAccountStatus @default(draft)
  source             String                  @default("manual")
  legacyKey          String?                 @unique
  legalName          String?
  documentNumber     String?
  contactEmail       String?
  contactPhone       String?
  notes              String?
  commercialCategory String?
  createdByUserId    String?
  approvedByUserId   String?
  approvedAt         DateTime?

  createdBy     User?                  @relation("AdvertiserAccountCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy    User?                  @relation("AdvertiserAccountApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  memberships   AdvertiserMembership[]
  campaigns     AdCampaign[]
  wallet        AdvertiserWallet?
  paymentOrders AdPaymentOrder[]
  creditEntries AdCreditLedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, type])
  @@index([name])
}

model AdvertiserWallet {
  id        String   @id @default(uuid())
  accountId String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account AdvertiserAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model AdPaymentOrder {
  id                String            @id @default(uuid())
  accountId         String
  campaignId        String?
  provider          AdPaymentProvider @default(mock)
  status            AdPaymentStatus   @default(created)
  packageCode       String
  amountCents       Int
  creditAmount      Int
  currency          String            @default("BRL")
  externalReference String            @unique
  providerPaymentId String?           @unique
  idempotencyKey    String            @unique
  returnPath        String            @default("/workspace/anunciante")
  createdByUserId   String
  metadata          Json?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  refundedAt        DateTime?
  expiresAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  account   AdvertiserAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign  AdCampaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy User                  @relation("AdPaymentOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  entries   AdCreditLedgerEntry[]

  @@index([accountId, createdAt])
  @@index([status, createdAt])
  @@index([campaignId])
}

model AdCreditLedgerEntry {
  id              String             @id @default(uuid())
  accountId       String
  campaignId      String?
  paymentOrderId  String?
  type            AdCreditLedgerType
  delta           Int
  balanceAfter    Int
  idempotencyKey  String             @unique
  description     String?
  metadata        Json?
  createdByUserId String?
  createdAt       DateTime           @default(now())

  account      AdvertiserAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign     AdCampaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  paymentOrder AdPaymentOrder?   @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  createdBy    User?             @relation("AdCreditLedgerEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([campaignId, createdAt])
  @@index([paymentOrderId])
}

model AdvertiserMembership {
  id              String                     @id @default(uuid())
  accountId       String
  userId          String
  role            AdvertiserMembershipRole   @default(viewer)
  status          AdvertiserMembershipStatus @default(invited)
  invitedByUserId String?
  acceptedAt      DateTime?

  account   AdvertiserAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User              @relation("AdvertiserMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?             @relation("AdvertiserMembershipInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, userId])
  @@index([userId, status])
  @@index([accountId, status])
}

model AdCreative {
  id                      String          @id @default(uuid())
  campaignId              String
  slot                    AdSlot
  title                   String?
  imageUrl                String
  destinationUrl          String?
  altText                 String?
  width                   Int?
  height                  Int?
  isEnabled               Boolean         @default(true)
  storageProvider         String?
  storageKey              String?
  mimeType                String?
  fileSizeBytes           Int?
  checksum                String?
  assetVersion            Int             @default(1)
  reviewStatus            AdReviewStatus?
  submittedAt             DateTime?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  reviewedByUserId        String?
  reviewNotes             String?
  requiresReviewAfterEdit Boolean         @default(false)

  campaign   AdCampaign   @relation(fields: [campaignId], references: [id])
  reviewedBy User?        @relation("AdCreativeReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  events     AdEventLog[]
  deliveries AdDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slot, isEnabled])
  @@index([storageProvider, storageKey])
  @@index([reviewStatus, submittedAt])
}

model AdReviewLog {
  id          String             @id @default(uuid())
  entityType  AdReviewEntityType
  entityId    String
  action      AdReviewAction
  fromStatus  AdReviewStatus?
  toStatus    AdReviewStatus
  actorUserId String?
  reason      String?
  snapshot    Json?
  createdAt   DateTime           @default(now())

  actor User? @relation("AdReviewLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

model AdEventLog {
  id         String      @id @default(uuid())
  type       AdEventType
  slot       AdSlot
  campaignId String
  creativeId String
  venueId    String?
  userId     String?
  sessionId  String?
  userAgent  String?
  ipHash     String?
  deliveryId String?
  createdAt  DateTime    @default(now())

  campaign AdCampaign  @relation(fields: [campaignId], references: [id])
  creative AdCreative  @relation(fields: [creativeId], references: [id])
  delivery AdDelivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  venue    Venue?      @relation(fields: [venueId], references: [id])
  user     User?       @relation(fields: [userId], references: [id])

  @@unique([deliveryId, type])
  @@index([campaignId, type, createdAt])
  @@index([creativeId, type, createdAt])
  @@index([userId, type, createdAt])
  @@index([venueId, type, createdAt])
  @@index([deliveryId, type])
}

model AdDelivery {
  id                   String    @id @default(uuid())
  token                String    @unique
  slot                 AdSlot
  campaignId           String
  creativeId           String
  venueId              String?
  userId               String?
  sessionHash          String?
  context              Json?
  expiresAt            DateTime
  renderedAt           DateTime?
  impressionRecordedAt DateTime?
  clickRecordedAt      DateTime?
  createdAt            DateTime  @default(now())

  campaign AdCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creative AdCreative   @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  events   AdEventLog[]

  @@index([slot, createdAt])
  @@index([campaignId, createdAt])
  @@index([creativeId, createdAt])
  @@index([sessionHash, createdAt])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Venue {
  id                                     String    @id @default(uuid())
  name                                   String
  slug                                   String    @unique
  goldPartner                            Boolean   @default(false)
  analyticsTier                          String    @default("basic")
  analyticsAccessSource                  String?
  analyticsAccessUntil                   DateTime?
  description                            String?
  contactName                            String?
  contactPhone                           String?
  instagramUrl                           String?
  address                                String
  latitude                               Float?
  longitude                              Float?
  neighborhood                           String
  nickname                               String?
  grammarArticle                         String?
  grammarPreposition                     String?   @default("em")
  displayNameWithArticle                 String?
  displayNameWithPreposition             String?
  nicknameGrammarArticle                 String?
  nicknameGrammarPreposition             String?   @default("em")
  nicknameDisplayNameWithArticle         String?
  nicknameDisplayNameWithPreposition     String?
  neighborhoodGrammarArticle             String?
  neighborhoodGrammarPreposition         String?   @default("em")
  neighborhoodDisplayNameWithArticle     String?
  neighborhoodDisplayNameWithPreposition String?
  region                                 String
  city                                   String
  state                                  String
  imageUrl                               String?
  openDays                               String[]
  createdByUserId                        String?
  managerUserId                          String?

  events           Event[]
  createdBy        User?                 @relation("VenueCreatedBy", fields: [createdByUserId], references: [id])
  manager          User?                 @relation("VenueManagedBy", fields: [managerUserId], references: [id])
  managerAccesses  VenueManagerAccess[]
  producerAccesses ProducerVenueAccess[]
  claimRequests    ClaimRequest[]        @relation("ClaimVenue")
  adEvents         AdEventLog[]
  menu             VenueMenu?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VenueMenu {
  id                          String          @id @default(uuid())
  venueId                     String          @unique
  status                      VenueMenuStatus @default(draft)
  pricesVisible               Boolean         @default(true)
  reviewedAt                  DateTime?
  reviewedByUserId            String?
  adInventoryAcceptedAt       DateTime?
  adInventoryAcceptedByUserId String?
  adInventoryPolicyVersion    String?
  publishedAt                 DateTime?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  venue                 Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  reviewedBy            User?           @relation("VenueMenuReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  adInventoryAcceptedBy User?           @relation("VenueMenuAdInventoryAcceptedBy", fields: [adInventoryAcceptedByUserId], references: [id], onDelete: SetNull)
  items                 VenueMenuItem[]

  @@index([status, updatedAt])
}

model VenueMenuItem {
  id           String              @id @default(uuid())
  menuId       String
  category     String
  name         String
  description  String?
  priceCents   Int?
  priceMode    VenueMenuPriceMode  @default(exact)
  servingLabel String?
  status       VenueMenuItemStatus @default(draft)
  tags         String[]
  isHighlight  Boolean             @default(false)
  sortOrder    Int                 @default(0)
  archivedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  menu         VenueMenu              @relation(fields: [menuId], references: [id], onDelete: Cascade)
  interactions VenueMenuInteraction[]

  @@index([menuId, status, category, sortOrder])
}

model VenueMenuInteraction {
  id        String                   @id @default(uuid())
  userId    String
  itemId    String
  type      VenueMenuInteractionType
  createdAt DateTime                 @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item VenueMenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId, type])
  @@index([itemId, type])
  @@index([userId, createdAt])
}

model ProducerVenueAccess {
  id         String   @id @default(uuid())
  producerId String
  venueId    String
  createdAt  DateTime @default(now())

  producer User  @relation(fields: [producerId], references: [id])
  venue    Venue @relation(fields: [venueId], references: [id])

  @@unique([producerId, venueId])
  @@index([producerId])
  @@index([venueId])
}

model VenueManagerAccess {
  id        String   @id @default(uuid())
  userId    String
  venueId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])

  @@unique([userId, venueId])
  @@index([userId])
  @@index([venueId])
}

model Event {
  id                   String     @id @default(uuid())
  title                String
  description          String?
  imageUrl             String?
  posterImageUrl       String?
  type                 EventType
  tags                 String[]
  startDate            DateTime
  endDate              DateTime
  isRecurring          Boolean    @default(false)
  recurrenceDays       String[]   @default([])
  recurrenceStartTime  String?
  recurrenceEndTime    String?
  recurrenceUntil      DateTime?
  recurrenceExceptions DateTime[] @default([])
  ticketType           String
  ticketUrl            String?
  priceMin             Float?
  priceMax             Float?
  consumacaoValue      Float?
  couvertArtistico     Float?
  pricingPolicy        Json?
  status               String     @default("confirmed")
  isDemo               Boolean    @default(false)
  createdByUserId      String?

  venueId   String
  venue     Venue  @relation(fields: [venueId], references: [id])
  createdBy User?  @relation("EventCreatedBy", fields: [createdByUserId], references: [id])

  artists             EventArtist[]
  markedBy            MarkedEvent[]
  historyBy           UserEventHistory[]
  itineraryItems      ItineraryItem[]
  toNaPistaDeliveries ToNaPistaDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDemo, startDate])
}

model Artist {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  bio              String?
  contactName      String?
  contactPhone     String?
  imageUrl         String?
  genres           String[]
  isVerified       Boolean   @default(false)
  verifiedAt       DateTime?
  verifiedByUserId String?
  spotifyUrl       String?
  youtubeUrl       String?
  instagramUrl     String?
  createdByUserId  String?

  events              EventArtist[]
  createdBy           User?                      @relation("ArtistCreatedBy", fields: [createdByUserId], references: [id])
  producerAccesses    ProducerArtistAccess[]
  claimRequests       ClaimRequest[]             @relation("ClaimArtist")
  followers           ArtistFollow[]
  professionalProfile ArtistProfessionalProfile?
  accesses            ArtistAccess[]
  verifiedBy          User?                      @relation("ArtistVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  bookingRequests     ArtistBookingRequest[]
  media               ArtistMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArtistProfessionalProfile {
  id                     String   @id @default(uuid())
  artistId               String   @unique
  coverImageUrl          String?
  shortBio               String?
  fullBio                String?
  baseCity               String?
  baseState              String?
  serviceRegions         String[] @default([])
  showFormats            String[] @default([])
  eventTypes             String[] @default([])
  averageDurationMinutes Int?
  formation              String?
  availability           String?
  websiteUrl             String?
  tiktokUrl              String?
  whatsappUrl            String?
  soundcloudUrl          String?
  professionalEmail      String?
  professionalPhone      String?
  contactPreference      String?

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArtistAccess {
  id              String             @id @default(uuid())
  artistId        String
  userId          String
  role            ArtistAccessRole   @default(viewer)
  status          ArtistAccessStatus @default(invited)
  invitedByUserId String?
  acceptedAt      DateTime?

  artist    Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  user      User   @relation("ArtistAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?  @relation("ArtistAccessInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([artistId, userId])
  @@index([userId, status])
  @@index([artistId, status])
}

model ArtistBookingRequest {
  id                String              @id @default(uuid())
  artistId          String
  requesterUserId   String?
  requesterName     String
  requesterEmail    String
  requesterPhone    String?
  desiredDate       DateTime?
  city              String
  neighborhood      String?
  eventType         String
  estimatedAudience Int?
  budgetRange       String?
  message           String
  status            ArtistBookingStatus @default(new)
  source            String              @default("artist_epk")
  lastStatusAt      DateTime            @default(now())

  artist    Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  requester User?  @relation("ArtistBookingRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([artistId, status, createdAt])
  @@index([requesterUserId, createdAt])
}

model ArtistMedia {
  id              String          @id @default(uuid())
  artistId        String
  type            ArtistMediaType
  url             String
  thumbnailUrl    String?
  title           String?
  caption         String?
  altText         String?
  storageProvider String?
  storageKey      String?
  mimeType        String?
  fileSizeBytes   Int?
  sortOrder       Int             @default(0)
  isPublished     Boolean         @default(true)

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([artistId, type, isPublished, sortOrder])
}

model ArtistFollow {
  id        String   @id @default(uuid())
  userId    String
  artistId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  artist Artist @relation(fields: [artistId], references: [id])

  @@unique([userId, artistId])
  @@index([artistId, createdAt])
}

model ProducerArtistAccess {
  id         String   @id @default(uuid())
  producerId String
  artistId   String
  createdAt  DateTime @default(now())

  producer User   @relation(fields: [producerId], references: [id])
  artist   Artist @relation(fields: [artistId], references: [id])

  @@unique([producerId, artistId])
  @@index([producerId])
  @@index([artistId])
}

model EventArtist {
  eventId  String
  artistId String
  order    Int    @default(0)

  event  Event  @relation(fields: [eventId], references: [id])
  artist Artist @relation(fields: [artistId], references: [id])

  @@id([eventId, artistId])
}

model MarkedEvent {
  id      String @id @default(uuid())
  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model UserEventHistory {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@index([userId, createdAt])
}

model Achievement {
  id          String @id @default(uuid())
  key         String @unique
  name        String
  description String
  icon        String
  points      Int
  requirement Json

  users UserAchievement[]
}

model UserAchievement {
  id            String @id @default(uuid())
  userId        String
  achievementId String

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt DateTime @default(now())

  @@unique([userId, achievementId])
}

model ClaimRequest {
  id                          String          @id @default(uuid())
  requestedById               String
  targetType                  ClaimTargetType
  venueId                     String?
  artistId                    String?
  responsibleName             String?
  responsiblePhone            String?
  claimantDocument            String?
  relationshipRole            String?
  officialEmail               String?
  officialInstagram           String?
  officialWebsite             String?
  justification               String?
  requestType                 String          @default("ownership")
  requestedChanges            Json?
  legalAcknowledgedAt         DateTime?
  legalAcknowledgementVersion String?
  status                      ClaimStatus     @default(pending)
  reviewedById                String?
  reviewedAt                  DateTime?
  decisionNote                String?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  requestedBy User    @relation("ClaimRequestedBy", fields: [requestedById], references: [id])
  reviewedBy  User?   @relation("ClaimReviewedBy", fields: [reviewedById], references: [id])
  venue       Venue?  @relation("ClaimVenue", fields: [venueId], references: [id])
  artist      Artist? @relation("ClaimArtist", fields: [artistId], references: [id])

  @@index([requestedById, status])
  @@index([targetType, status])
}

model AcquisitionLead {
  id                 String                     @id @default(uuid())
  venueName          String
  city               String                     @default("São Paulo")
  region             String?
  neighborhood       String?
  address            String?
  addressNumber      String?
  addressComplement  String?
  zipCode            String?
  latitude           Float?
  longitude          Float?
  instagramUrl       String?
  phone              String?
  contactName        String?
  contactRole        String?
  email              String?
  status             String                     @default("mapped")
  temperature        String                     @default("warm")
  nextFollowUpAt     DateTime?
  presentationAt     DateTime?
  presentationFormat String?
  source             String?
  potential          String?
  objections         String?
  notes              String?
  createdByUserId    String?
  createdBy          User?                      @relation("AcquisitionLeadCreatedBy", fields: [createdByUserId], references: [id])
  interactions       AcquisitionInteraction[]
  statusHistory      AcquisitionStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([temperature])
  @@index([nextFollowUpAt])
  @@index([city, region])
}

model AcquisitionStatusHistory {
  id              String   @id @default(uuid())
  leadId          String
  fromStatus      String?
  toStatus        String
  changedByUserId String?
  changedAt       DateTime @default(now())

  lead      AcquisitionLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  changedBy User?           @relation("AcquisitionStatusChangedBy", fields: [changedByUserId], references: [id])

  @@index([leadId, changedAt])
  @@index([toStatus, changedAt])
  @@index([changedByUserId, changedAt])
}

model AcquisitionInteraction {
  id              String    @id @default(uuid())
  leadId          String
  type            String    @default("note")
  summary         String
  nextAction      String?
  nextFollowUpAt  DateTime?
  createdByUserId String?

  lead      AcquisitionLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("AcquisitionInteractionCreatedBy", fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([nextFollowUpAt])
}
